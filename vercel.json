{
  "version": 2,
  "cleanUrls": true,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/game", "dest": "/public/game.html" },
    { "src": "/game.html", "dest": "/public/game.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
